# Copy to .env and edit before running `docker compose up -d`.

# --- PostgreSQL ---------------------------------------------------------------
POSTGRES_DB=change_mgmt
POSTGRES_USER=change_mgmt
POSTGRES_PASSWORD=please-change-me

# --- API server ---------------------------------------------------------------
# Used to sign session JWT cookies. Generate with:  openssl rand -hex 64
JWT_SECRET=replace-with-a-long-random-string
# pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# --- Web server (Nginx + TLS) -------------------------------------------------
# Host ports the reverse proxy publishes.
HTTP_PORT=80
HTTPS_PORT=443

# Set DISABLE_TLS=true to serve HTTP only (NOT recommended for production).
DISABLE_TLS=false

# Hostname embedded into the auto-generated self-signed cert (only used when
# you have not provided your own cert in ./certs/server.crt + ./certs/server.key).
TLS_HOSTNAME=change-mgmt.local
TLS_SELFSIGNED_DAYS=365

# To use your own certificate, drop the files into ./certs/:
#   ./certs/server.crt
#   ./certs/server.key
# The web container will pick them up instead of generating a self-signed cert.
# Certificates can also be uploaded later through the in-app SSL settings page;
# the entrypoint will reuse whatever it finds in /etc/nginx/certs on next restart.
